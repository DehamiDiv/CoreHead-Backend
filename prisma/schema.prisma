generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_layouts {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  prompt           String
  layout_type      String?   @db.VarChar(50)
  design_style     String?   @db.VarChar(50)
  features         Json?
  generated_layout Json
  created_at       DateTime? @default(now()) @db.Timestamp(6)
}

model authors {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  bio          String?
  avatar       String?   @db.VarChar(500)
  social_links Json?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model builder_layouts {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  layout_data  Json
  content_mode String?   @default("static") @db.VarChar(20)
  grid_layout  String?   @default("grid") @db.VarChar(50)
  user_id      Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([updated_at(sort: Desc)], map: "idx_builder_layouts_updated")
  @@index([user_id], map: "idx_builder_layouts_user")
}

model categories {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  password    String
  role        String     @default("user")
  name        String?    @db.VarChar(255)
  designation String?    @db.VarChar(255)
  bio         String?
  avatar      String?    @db.Text

  templates   Template[]
  posts       Post[]
  pages       Page[]

  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("users")
}

model Template {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  category    String?
  status      String   @default("draft")
  layoutJson  Json

  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])

  version     Int      @default(1)
  history     TemplateHistory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("templates")
}

model TemplateHistory {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  version     Int
  layoutJson  Json
  updatedBy   Int

  createdAt   DateTime @default(now())
}

model Post {
  id             Int       @id @default(autoincrement())
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  excerpt        String?
  content        String    @map("body")
  imageUrl       String?   @map("featured_image") @db.VarChar(500)
  status         String?   @default("draft") @db.VarChar(20)
  category       String?   @db.VarChar(100)
  tags           String[]

  authorId       Int?      @map("author_id")
  author         User?     @relation(fields: [authorId], references: [id])

  published_date DateTime? @db.Timestamp(6)
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("posts")
}

model Page {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  htmlContent String   @map("html_content")
  status      String   @default("Draft") @db.VarChar(50)
  
  authorId    Int?     @map("author_id")
  author      User?    @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("pages")
}