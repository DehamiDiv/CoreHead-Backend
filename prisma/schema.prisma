generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_layouts {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  prompt           String
  layout_type      String?   @db.VarChar(50)
  design_style     String?   @db.VarChar(50)
  features         Json?
  generated_layout Json
  created_at       DateTime? @default(now()) @db.Timestamp(6)
}

model authors {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  bio          String?
  avatar       String?   @db.VarChar(500)
  social_links Json?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

model builder_layouts {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  layout_data  Json
  content_mode String?   @default("static") @db.VarChar(20)
  grid_layout  String?   @default("grid") @db.VarChar(50)
  user_id      Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([updated_at(sort: Desc)], map: "idx_builder_layouts_updated")
  @@index([user_id], map: "idx_builder_layouts_user")
}

model categories {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  password    String
  name        String?
  nicename    String?
  designation String?
  bio         String?
  avatar      String?
  role        String     @default("user")
  createdAt   DateTime?  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime?  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)
  Binding     Binding[]
  posts       Post[]
  templates   Template[]
  comments    Comment[]

  @@map("users")
}

model Media {
  id        Int       @id @default(autoincrement())
  name      String
  type      String
  size      String
  url       String
  isDeleted Boolean?  @default(false) @map("is_deleted")
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("media")
}

model Setting {
  id        Int       @id @default(autoincrement())
  key       String    @unique
  value     Json
  createdAt DateTime? @default(now()) @map("created_at")
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("settings")
}

model Page {
  id          Int       @id @default(autoincrement())
  name        String
  slug        String    @unique
  htmlContent String?   @map("html_content")
  status      String    @default("Draft")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("pages")
}

model Comment {
  id         Int       @id @default(autoincrement())
  content    String
  status     String    @default("pending")
  postId     Int?      @map("post_id")
  post       Post?     @relation(fields: [postId], references: [id])
  userId     Int?      @map("user_id")
  user       User?     @relation(fields: [userId], references: [id])
  userName   String?   @map("user_name")
  userAvatar String?   @map("user_avatar")
  createdAt  DateTime? @default(now()) @map("created_at")
  updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at")

  @@map("comments")
}

model Template {
  id          Int      @id @default(autoincrement())
  name        String
  type        String
  category    String?
  status      String   @default("draft")
  layoutJson  Json

  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])

  version     Int      @default(1)
  history     TemplateHistory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("templates")
}

model TemplateHistory {
  id          Int      @id @default(autoincrement())
  templateId  Int
  template    Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  version     Int
  layoutJson  Json
  updatedBy   Int

  createdAt   DateTime @default(now())
}

model Post {
  id          Int       @id @default(autoincrement())
  title       String
  slug        String    @unique
  excerpt     String?
  content     String    @map("body")
  coverImage  String?   @map("featured_image")
  category    String?
  tags        String[]
  isPublished Boolean   @default(false)
  publishedAt DateTime? @map("published_date")
  status      String    @default("published")
  featured    Boolean?  @default(false)
  authorId    Int?      @map("author_id")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at")
  author      User?     @relation(fields: [authorId], references: [id])
  comments    Comment[]

  @@map("posts")
}

model Binding {
  id        String   @id
  mode      String
  selected  Json
  userId    Int?
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
}

model PageLayout {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  name      String
  layout    Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
