generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ai_layouts {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  prompt           String
  layout_type      String?   @db.VarChar(50)
  design_style     String?   @db.VarChar(50)
  features         Json?
  generated_layout Json
  created_at       DateTime? @default(now()) @db.Timestamp(6)
}

model authors {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(100)
  email        String    @unique @db.VarChar(255)
  bio          String?
  avatar       String?   @db.VarChar(500)
  social_links Json?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model builder_layouts {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(255)
  layout_data  Json
  content_mode String?   @default("static") @db.VarChar(20)
  grid_layout  String?   @default("grid") @db.VarChar(50)
  user_id      Int?
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  updated_at   DateTime? @default(now()) @db.Timestamp(6)

  @@index([updated_at(sort: Desc)], map: "idx_builder_layouts_updated")
  @@index([user_id], map: "idx_builder_layouts_user")
}

model categories {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
}

model posts {
  id             Int       @id @default(autoincrement())
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  excerpt        String?
  body           String
  featured_image String?   @db.VarChar(500)
  category       String?   @db.VarChar(100)
  tags           String[]
  author_id      Int?
  status         String?   @default("draft") @db.VarChar(20)
  published_date DateTime? @db.Timestamp(6)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  updated_at     DateTime? @default(now()) @db.Timestamp(6)

  @@index([author_id], map: "idx_posts_author")
  @@index([category], map: "idx_posts_category")
  @@index([published_date], map: "idx_posts_published_date")
  @@index([status], map: "idx_posts_status")
}
